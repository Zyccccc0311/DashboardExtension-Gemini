<?xml version="1.0" encoding="utf-8"?>
<manifest manifest-version="0.1" xmlns="http://www.tableau.com/xml/extension_manifest">
  <dashboard-extension id="com.example.myfirstdemo" extension-version="1.0.0">
    <default-locale>zh_CN</default-locale>
    <name resource-id="网页内嵌 Demo"/>
    <description>测试在 Tableau 中嵌入外部网页</description>
    <author name="AI Developer" email="dev@example.com" organization="MyOrg" website="https://example.com"/>
    <min-api-version>1.0</min-api-version>
    <source-location>
      <url>http://localhost:8080/index.html</url>
    </source-location>
    <icon></icon>
  </dashboard-extension>
    <resources>
    <resource id="网页内嵌 Demo">
      <text locale="zh_CN">网页内嵌 Demo</text>
    </resource>
  </resources>
</manifest>