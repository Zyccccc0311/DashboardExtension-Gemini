<?xml version="1.0" encoding="utf-8"?>
<manifest manifest-version="0.1" xmlns="http://www.tableau.com/xml/extension_manifest">
  <dashboard-extension id="com.gemini.extension.shell" extension-version="1.0.0">
    <default-locale>zh_CN</default-locale>
    <name resource-id="extension-name" />
    <description>最小可用的 Tableau Dashboard Extension，用于验证扩展能在 Tableau 中正常显示。</description>
    <author
      name="Codex"
      email="dev@example.com"
      organization="Gemini1"
      website="https://example.com" />
    <min-api-version>1.0</min-api-version>
    <source-location>
      <url>http://localhost:8080/index.html</url>
    </source-location>
    <icon />
  </dashboard-extension>
  <resources>
    <resource id="extension-name">
      <text locale="zh_CN">最小 Tableau 扩展壳</text>
      <text locale="en_US">Minimal Tableau Extension Shell</text>
    </resource>
  </resources>
</manifest>
